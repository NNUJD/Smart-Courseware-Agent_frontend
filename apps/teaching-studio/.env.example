TEACHING_BACKEND_BASE_URL=http://127.0.0.1:8000
TEACHING_BACKEND_USER_ID=teacher-001
TEACHING_BACKEND_AUTO_ONLINE_IMAGE_SEARCH=false
TEACHING_DEMO_MODE=false
TEACHING_DEMO_CHAT_MODE=auto
TEACHING_DEMO_DELAY_MS=12000
NEXT_PUBLIC_TEACHING_TRIGGER_AFTER_ASSISTANT=true

# Optional: allow preview/export routes to read generated files directly.
# Use an absolute path when the frontend runs outside the monorepo root.
# TEACHING_BACKEND_ARTIFACT_ROOT=../../../Smart-Courseware-Agent_backend/backend/app/agent/data_assets/demo_show

# Optional: override LibreOffice `soffice` executable used for PPT/DOCX preview.
# Leave empty to auto-detect common locations or use `soffice` from PATH.
# SOFFICE_PATH=

# chat persistence -- sign up on cloud.assistant-ui.com
# NEXT_PUBLIC_ASSISTANT_BASE_URL=
